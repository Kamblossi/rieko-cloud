generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CloudSession {
  id         String    @id @default(cuid())
  licenseKey String
  machineId  String
  instanceId String
  isAdmin    Boolean   @default(false)
  planCode   String?
  tier       String?
  capabilitiesJson Json? @map("capabilities_json")
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([licenseKey, machineId, createdAt])
}

model RiekoModel {
  id                 String   @id @default(cuid())
  displayName        String
  providerLabel      String
  routingKey         String   @unique
  modality           String
  isAvailable        Boolean  @default(true)
  sortOrder          Int      @default(0)
  isManualSelectable Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isAvailable, sortOrder])
}

model PromptTemplate {
  id              String   @id @default(cuid())
  title           String
  prompt          String
  defaultModelKey String
  active          Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@index([active, updatedAt])
}

model UsageEvent {
  id            String   @id @default(cuid())
  licenseKey    String
  machineId     String
  instanceId    String
  modelKey      String
  eventType     String   @default("generic") @map("event_type")
  consumesQuota Boolean  @default(false) @map("consumes_quota")
  usageJson     Json
  createdAt     DateTime @default(now())

  @@index([licenseKey, createdAt])
  @@index([licenseKey, consumesQuota, createdAt])
}

model RoutingProfile {
  id                String   @id @default(cuid())
  taskType          String
  modality          String
  latencyPreference String?
  preferredModelKey String
  fallbackJson      Json?
  maxTokens         Int?
  temperature       Float?
  active            Boolean  @default(true)

  @@index([taskType, modality, active])
}
